{
  "name": "luxurystay-hms",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "build": "npm run build:server && npm run build:client",
    "lint": "npm run lint:server && npm run lint:client",
    "preview": "npm run preview --workspace client",
    "dev:client": "npm run dev --workspace client",
    "build:client": "npm run build --workspace client",
    "lint:client": "npm run lint --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build:server": "npm run build --workspace server",
    "lint:server": "npm run lint --workspace server",
    "seed:server": "npm run seed --workspace server",
    "test:server": "npm run test --workspace server"
  }
}
